# Limine configuration (protocol v11)
# Template: @PRODUCT_NAME@, @INIT_PACKAGE@ and @VOLUME_PACKAGE@ are substituted by
# boot/mkimage.sh (render_conf) from product.conf.
timeout: 0

/@PRODUCT_NAME@
	protocol: limine
	path: boot():/boot/kernel
	module_path: boot():/boot/@INIT_PACKAGE@
	module_path: boot():/boot/@VOLUME_PACKAGE@
