# Development commands
# Run from the src/ directory (where this Justfile lives).

kernel_dir := "kernel"
user_dir := "user/system_manager"
services_dir := "user/services"
storage_dir := "user/storage"
drivers_dir := "user/drivers"
usertools_dir := "user/tools"
rt_dir := "user/rt"
abi_dir := "abi"
tools_dir := "tools/lsidl-gen"
proto_dir := "proto"
wasm_dir := "wasm"
sdk_dir := "sdk"
term_dir := "term"
liberfs_dir := "fs/liberfs"
fat_dir := "fs/fat"
iso9660_dir := "fs/iso9660"
target := "x86_64-unknown-none"
kernel_elf := kernel_dir / "target" / target / "debug" / "kernel"

# default: build and run in QEMU
default: run

# build the userspace programs that make up the init package
user:
	cd {{user_dir}} && cargo build
	cd {{services_dir}} && cargo build
	cd {{storage_dir}} && cargo build
	cd {{drivers_dir}} && cargo build
	cd {{usertools_dir}} && cargo build

# build the WebAssembly component SDK example (the `liber` world guest) for
# wasm32-unknown-unknown and stage it into the ramdisk volume as app.wasm, where
# StorageService serves it over vol:// for the component_host to load and run
sdk:
	cd {{sdk_dir}} && cargo build --release --target wasm32-unknown-unknown
	cp {{sdk_dir}}/target/wasm32-unknown-unknown/release/liber_component.wasm volume/app.wasm

# build the kernel (its build.rs assembles the init package from the userspace build)
build: sdk user
	cd {{kernel_dir}} && cargo build

# generate the proto crate's bindings from the LSIDL interface definitions
# (src/idl/*.lsidl) and format the generated source
gen:
	cd {{tools_dir}} && cargo run --quiet -- --rust-dir ../../{{proto_dir}}/src --docs-dir ../../../docs/gen ../../idl/*.lsidl
	cd {{proto_dir}} && cargo fmt

# build + boot in QEMU (serial on stdout). Add live displays as arguments
# (combinable): `just run`, `just run vnc`, `just run spice`, `just run vnc spice`
run *displays: sdk user
	cd {{kernel_dir}} && DISPLAYS="{{displays}}" cargo run

# build + boot, QEMU waits for GDB (port :1234)
debug: sdk user
	cd {{kernel_dir}} && DEBUG=1 NOKVM=1 cargo run

# attach GDB to a running QEMU (run in a second panel after 'just debug')
gdb:
	gdb -x boot/gdb-init {{kernel_elf}}

# run tests in QEMU (isa-debug-exit)
test: sdk user
	cd {{kernel_dir}} && TEST=1 cargo test

# screenshot the framebuffer to a file (format by extension: png/jpg/webp/...);
# snaps a live `just run` if one is up, else boots a throwaway. e.g. just screenshot shot.png
screenshot path: build
	boot/screenshot.sh {{path}}

# build a bootable hybrid ISO (BIOS + UEFI) -> boot/.build/<product>.iso; STRIP=debug|all
iso strip="debug": build
	STRIP={{strip}} boot/mkimage.sh iso {{kernel_elf}}

# build a raw bootable disk image for USB / SD card / HDD (BIOS + UEFI); SIZE e.g. 128M, 1G; STRIP=debug|all
img size="64M" strip="debug": build
	STRIP={{strip}} boot/mkimage.sh img {{kernel_elf}} {{size}}

# format all code (Rust via rustfmt, shell via shfmt)
fmt:
	cd {{abi_dir}} && cargo fmt
	cd {{rt_dir}} && cargo fmt
	cd {{kernel_dir}} && cargo fmt
	cd {{user_dir}} && cargo fmt
	cd {{services_dir}} && cargo fmt
	cd {{storage_dir}} && cargo fmt
	cd {{drivers_dir}} && cargo fmt
	cd {{usertools_dir}} && cargo fmt
	cd {{tools_dir}} && cargo fmt
	cd {{proto_dir}} && cargo fmt
	cd {{wasm_dir}} && cargo fmt
	cd {{sdk_dir}} && cargo fmt
	cd {{term_dir}} && cargo fmt
	cd {{liberfs_dir}} && cargo fmt
	cd {{fat_dir}} && cargo fmt
	cd {{iso9660_dir}} && cargo fmt
	shfmt -w ../setup.sh boot/qemu-run.sh boot/mkimage.sh boot/screenshot.sh

# check formatting without writing changes (CI-friendly)
fmt-check:
	cd {{abi_dir}} && cargo fmt --check
	cd {{rt_dir}} && cargo fmt --check
	cd {{kernel_dir}} && cargo fmt --check
	cd {{user_dir}} && cargo fmt --check
	cd {{services_dir}} && cargo fmt --check
	cd {{storage_dir}} && cargo fmt --check
	cd {{drivers_dir}} && cargo fmt --check
	cd {{usertools_dir}} && cargo fmt --check
	cd {{tools_dir}} && cargo fmt --check
	cd {{proto_dir}} && cargo fmt --check
	cd {{wasm_dir}} && cargo fmt --check
	cd {{sdk_dir}} && cargo fmt --check
	cd {{term_dir}} && cargo fmt --check
	cd {{liberfs_dir}} && cargo fmt --check
	cd {{fat_dir}} && cargo fmt --check
	cd {{iso9660_dir}} && cargo fmt --check
	shfmt -d ../setup.sh boot/qemu-run.sh boot/mkimage.sh boot/screenshot.sh

# clean build artifacts
clean:
	cd {{abi_dir}} && cargo clean
	cd {{rt_dir}} && cargo clean
	cd {{kernel_dir}} && cargo clean
	cd {{user_dir}} && cargo clean
	cd {{services_dir}} && cargo clean
	cd {{storage_dir}} && cargo clean
	cd {{drivers_dir}} && cargo clean
	cd {{usertools_dir}} && cargo clean
	cd {{tools_dir}} && cargo clean
	cd {{proto_dir}} && cargo clean
	cd {{wasm_dir}} && cargo clean
	cd {{sdk_dir}} && cargo clean
	cd {{term_dir}} && cargo clean
	cd {{liberfs_dir}} && cargo clean
	cd {{fat_dir}} && cargo clean
	cd {{iso9660_dir}} && cargo clean
	rm -f volume/app.wasm
	rm -rf boot/.build
