# Measure every staged decoder in an optimized host build and fail below real time.
audio-bench:
	cargo run --release --manifest-path {{audio_bench_dir}}/Cargo.toml

# Regenerate every staged audio format and independent PCM golden from volume/test.mp3.
audio-fixtures:
	tools/generate-audio-tests.sh

# Measure current image encode/decode profiles in an optimized host build.
image-bench:
	cargo run --release --manifest-path {{image_bench_dir}}/Cargo.toml

# Validate every supported image profile with independent host implementations.
image-conformance: bmp-conformance gif-conformance ico-conformance icns-conformance jpeg-conformance pcx-conformance png-conformance ppm-conformance qoi-conformance tga-conformance webp-conformance

# Validate BMP decode/encode profiles with ImageMagick.
bmp-conformance:
	cargo run --release --manifest-path {{bmp_conformance_dir}}/Cargo.toml

# Validate GIF decode/encode profiles with ImageMagick and gifsicle.
gif-conformance:
	cargo run --release --manifest-path {{gif_conformance_dir}}/Cargo.toml

# Validate ICO decode/encode profiles with ImageMagick and icoutils.
ico-conformance:
	cargo run --release --manifest-path {{ico_conformance_dir}}/Cargo.toml

# Validate ICNS decode/encode profiles with icnsutils and ImageMagick.
icns-conformance:
	cargo run --release --manifest-path {{icns_conformance_dir}}/Cargo.toml

# Validate baseline JPEG profiles with ImageMagick and Pillow.
jpeg-conformance:
	cargo run --release --manifest-path {{jpeg_conformance_dir}}/Cargo.toml

# Validate PCX decode/encode profiles with ImageMagick and Netpbm.
pcx-conformance:
	cargo run --release --manifest-path {{pcx_conformance_dir}}/Cargo.toml

# Validate PNG/APNG profiles with pngcheck, ImageMagick, Pillow and apngdis.
png-conformance:
	cargo run --release --manifest-path {{png_conformance_dir}}/Cargo.toml

# Validate PPM decode/encode profiles with ImageMagick and Netpbm.
ppm-conformance:
	cargo run --release --manifest-path {{ppm_conformance_dir}}/Cargo.toml

# Validate QOI decode/encode profiles with ImageMagick and Netpbm.
qoi-conformance:
	cargo run --release --manifest-path {{qoi_conformance_dir}}/Cargo.toml

# Validate TGA decode/encode profiles with ImageMagick.
tga-conformance:
	cargo run --release --manifest-path {{tga_conformance_dir}}/Cargo.toml

# Validate VP8, VP8L, ALPH and animated WebP with libwebp and ImageMagick.
webp-conformance:
	cargo run --release --manifest-path {{webp_conformance_dir}}/Cargo.toml

# Run every image leaf and the central sniffer through deterministic hostile inputs.
image-mutate:
	cargo run --release --manifest-path {{image_mutate_dir}}/Cargo.toml

