	cd {{tools_dir}} && cargo run --quiet -- --rust-dir ../../user/process-proto/src --rust-package liber:process@1 --external-rust-package liber:base@1=base_proto::generated::liber::base ../../idl/*.lsidl
	cd {{tools_dir}} && cargo run --quiet -- --rust-dir ../../user/display-proto/src --rust-package liber:display@1 --external-rust-package liber:base@1=base_proto::generated::liber::base --external-rust-package liber:process@1=process_proto::generated::liber::process ../../idl/*.lsidl
	cd {{tools_dir}} && cargo run --quiet -- --rust-dir ../../user/security-proto/src --rust-package liber:security@1 --external-rust-package liber:base@1=base_proto::generated::liber::base --external-rust-package liber:process@1=process_proto::generated::liber::process ../../idl/*.lsidl
	cd {{tools_dir}} && cargo run --quiet -- --rust-dir ../../user/input-proto/src --rust-package liber:input@1 --external-rust-package liber:base@1=base_proto::generated::liber::base ../../idl/*.lsidl
