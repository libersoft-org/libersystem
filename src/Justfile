# discard all image caches and rerun the complete compile/link/audit path
shared-libs-verify:
	LIBER_IMAGE_REBUILD=1 just shared-libs

# Validate warm, one-tool or provider invalidation without retaining source mutations.
shared-cache-check mode="quick":
