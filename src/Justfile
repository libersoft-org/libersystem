	cd {{rt_dir}} && cargo clean
	cd {{kernel_dir}} && cargo clean
	cd {{user_dir}} && cargo clean
	cd {{services_dir}} && cargo clean
	cd {{storage_dir}} && cargo clean
	cd {{drivers_dir}} && cargo clean
