# Reject an ET_EXEC mutation before it can rewrite any target's staged system volume.
static-image-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh static

# Reject a staged but undeclared DT_NEEDED provider before it can rewrite any target's system volume.
undeclared-edge-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh undeclared-edge

# Reject duplicate DT_NEEDED metadata before it can rewrite any target's staged system volume.
duplicate-edge-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh duplicate-edge

# Reject malformed PT_DYNAMIC metadata before it can rewrite any target's staged system volume.
malformed-dynamic-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh malformed-dynamic

# Reject malformed symbol and relocation metadata before it can rewrite any target's system volume.
malformed-symbol-relocation-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh malformed-symbol-relocation

# Reject canonical provider-order drift before it can rewrite any target's system volume.
dependency-graph-check: sdk user user-aarch64 user-riscv64
	tools/check-static-injection.sh dependency-graph

