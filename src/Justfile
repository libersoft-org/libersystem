	cd {{tools_dir}} && cargo run --quiet -- --accept-breaking --rust-dir ../../{{proto_dir}}/src --external-rust-package liber:base@1=base_proto::generated::liber::base --external-rust-package liber:display@1=display_proto::generated::liber::display --external-rust-package liber:input@1=input_proto::generated::liber::input --external-rust-package liber:process@1=process_proto::generated::liber::process --external-rust-package liber:security@1=security_proto::generated::liber::security --external-rust-package liber:storage@1=storage_proto::generated::liber::storage --docs-dir ../../../docs/gen ../../idl/*.lsidl
