# Build + boot one architecture through the unified QEMU runner. With no architecture,
# use the host architecture; an explicit first target runs natively or under emulation.
# A display may still be the first argument: `just run vnc` remains native.
# Examples: `just run`, `just run vnc`, `just run aarch64`, `just run riscv64 vnc`.
run *args:
	#!/usr/bin/env bash
	set -euo pipefail
	target=""
	displays=()
	for arg in {{args}}; do
	if [[ -z "$target" && ${#displays[@]} -eq 0 && "$arg" =~ ^(x86_64|aarch64|riscv64)$ ]]; then
		target="$arg"
	else
		displays+=("$arg")
	fi
	done
	if [[ -z "$target" ]]; then
	case "$(uname -m)" in
	x86_64) target=x86_64 ;;
	aarch64 | arm64) target=aarch64 ;;
	riscv64) target=riscv64 ;;
	*) echo "just run: unsupported host architecture '$(uname -m)'" >&2 && exit 1 ;;
	esac
	fi
	case "$target" in
	x86_64) just run-x86_64 "${displays[@]}" ;;
	aarch64) just run-aarch64 "${displays[@]}" ;;
	riscv64) just run-riscv64 "${displays[@]}" ;;
	*) echo "just run: unknown architecture '$target' (expected x86_64, aarch64, or riscv64)" >&2 && exit 1 ;;
	esac

# build + boot the x86_64 build in QEMU (native with KVM on an x86_64 host, emulated
# elsewhere). Add live displays as arguments (combinable): `just run-x86_64 vnc spice`.
run-x86_64 *displays: sdk user
	cd {{kernel_dir}} && cargo build
	DISPLAYS="{{displays}}" boot/qemu-run.sh x86_64 {{kernel_elf}}

# build + boot, QEMU waits for GDB (port :1234)
debug: sdk user
	cd {{kernel_dir}} && cargo build
	DEBUG=1 NOKVM=1 boot/qemu-run.sh x86_64 {{kernel_elf}}

# attach GDB to a running QEMU (run in a second panel after 'just debug')
gdb:
	gdb -x boot/gdb-init {{kernel_elf}}

# Run every x86_64 test in QEMU (isa-debug-exit). TEST_TIMEOUT overrides the
# 15-minute full-suite watchdog.
test: sdk user test-tags-check
	boot/test-kernel.sh x86_64

# Run the union of the requested x86_64 tags plus the smoke set.
test-tags tags: sdk user test-tags-check
	boot/test-kernel.sh x86_64 "{{tags}}"

# run the kernel test suite in QEMU on aarch64 (Arm semihosting exit maps pass/fail).
# SMP=4 exercises the multi-core paths (secondary bring-up, the cross-core wake IPI).
test-aarch64: sdk user-aarch64 test-tags-check
	boot/test-kernel.sh aarch64

# Run the union of the requested aarch64 tags plus the smoke set.
test-tags-aarch64 tags: sdk user-aarch64 test-tags-check
	SMP="${SMP:-4}" boot/test-kernel.sh aarch64 "{{tags}}"

# run the kernel test suite in QEMU on riscv64 over OpenSBI (RISC-V semihosting exit
# maps pass/fail). Defaults to `nproc` harts (like the x86 `test` recipe), exercising the
# multi-hart paths (SBI HSM hart_start bring-up, the SBI IPI cross-hart wake); override
# with `SMP=<n>` (a smaller count is faster under TCG on a many-core host).
test-riscv64: sdk user-riscv64 test-tags-check
	boot/test-kernel.sh riscv64

# Run the union of the requested riscv64 tags plus the smoke set.
test-tags-riscv64 tags: sdk user-riscv64 test-tags-check
	SMP="${SMP:-4}" boot/test-kernel.sh riscv64 "{{tags}}"

# Run all tests on all architectures. TCG guests are intentionally serial to avoid
# host contention; this is the periodic integration check, not the per-task path.
test-all: sdk user user-aarch64 user-riscv64 test-tags-check
	boot/test-all.sh

# A cheap source check; the Rust type system separately rejects unknown/empty tags.
test-tags-check:
	boot/check-test-tags.sh

# build the own UEFI loader for aarch64 (staged into the boot image as BOOTAA64.EFI)
loader-aarch64:
	cd {{loader_dir}} && cargo build --target aarch64-unknown-uefi

# build the own UEFI loader for riscv64 (staged into the boot image as BOOTRISCV64.EFI).
# There is no built-in riscv64 UEFI rustc target (and rustc's object backend cannot emit
# a riscv64 PE/COFF), so the loader is compiled as a static PIE on the ELF target and a
# hand-written PE/COFF header (src/arch/riscv64/head.rs) is prepended via the linker
# script (loader/riscv64-pe.ld); llvm-objcopy then flattens it into a valid EFI
# application, padded to the image end so its section raw data is fully backed.
loader-riscv64:
	cd {{loader_dir}} &&
	RUSTFLAGS="-C relocation-model=pic -C link-arg=-pie -C link-arg=-T$PWD/riscv64-pe.ld" \
		cargo build --target riscv64gc-unknown-none-elf &&
	END=$(llvm-readelf -s target/riscv64gc-unknown-none-elf/debug/libersystem-loader | awk '/ _pe_image_end$/{print "0x"$2; exit}') &&
	llvm-objcopy -O binary --pad-to "$END" \
		target/riscv64gc-unknown-none-elf/debug/libersystem-loader \
		target/riscv64gc-unknown-none-elf/debug/libersystem-loader.efi

# build + boot the ARM64 build in QEMU (native on an aarch64 host, emulated on an x86
# host), reaching the interactive shell over the serial console. Uses QEMU's direct
# -kernel load - the quick path; `run-aarch64-uefi` boots the same system through the
# own UEFI loader. Add live displays as arguments (combinable): `just run-aarch64 vnc spice`.
run-aarch64 *displays: sdk user-aarch64
	cd {{kernel_dir}} && cargo build --target aarch64-unknown-none
	DISPLAYS="{{displays}}" SERIAL=stdio bash boot/qemu-run.sh aarch64 {{kernel_dir}}/target/aarch64-unknown-none/debug/kernel

# build the userspace programs for riscv64 (the riscv64 kernel build.rs reads them from
# each crate's riscv64gc-unknown-none-elf target dir)
user-riscv64: shared-libs-riscv64
	cd {{user_dir}} && cargo build --target riscv64gc-unknown-none-elf
	cd {{services_dir}} && cargo build --target riscv64gc-unknown-none-elf
	cd {{storage_dir}} && cargo build --target riscv64gc-unknown-none-elf
	cd {{drivers_dir}} && cargo build --target riscv64gc-unknown-none-elf

# build + boot the riscv64 build in QEMU over OpenSBI (emulated on an x86 host),
# reaching the pinned userspace service chain over the serial console. The system
# volume is a polled virtio-blk disk (StorageService reads the factory archive from
# it), so no per-device interrupt path is needed for the core chain.
run-riscv64 *displays: sdk user-riscv64
	cd {{kernel_dir}} && cargo build --target riscv64gc-unknown-none-elf
	DISPLAYS="{{displays}}" SERIAL=stdio bash boot/qemu-run.sh riscv64 {{kernel_dir}}/target/riscv64gc-unknown-none-elf/debug/kernel

# build + boot the full riscv64 system through the own UEFI loader under U-Boot (the
# qemu-riscv64 S-mode U-Boot on OpenSBI, instead of QEMU's direct -kernel load): U-Boot's
# EFI boot manager launches /EFI/BOOT/BOOTRISCV64.EFI off the FAT ESP, which reads the
# kernel off the same volume, places it at its physical link addresses and enters the
# kernel's boot stub - the same entry state OpenSBI's -kernel boot produces.
run-riscv64-uefi *displays: sdk user-riscv64 loader-riscv64
	cd {{kernel_dir}} && cargo build --target riscv64gc-unknown-none-elf
	UEFI=1 DISPLAYS="{{displays}}" SERIAL=stdio bash boot/qemu-run.sh riscv64 {{kernel_dir}}/target/riscv64gc-unknown-none-elf/debug/kernel

# build + boot the full aarch64 system through the own UEFI loader under the AAVMF
# firmware (instead of QEMU's direct -kernel load), reaching the interactive shell.
# Add live displays as arguments (combinable): `just run-aarch64-uefi vnc spice`.
run-aarch64-uefi *displays: sdk user-aarch64 loader-aarch64
	cd {{kernel_dir}} && cargo build --target aarch64-unknown-none
	UEFI=1 DISPLAYS="{{displays}}" SERIAL=stdio bash boot/qemu-run.sh aarch64 {{kernel_dir}}/target/aarch64-unknown-none/debug/kernel

# screenshot the framebuffer to a file (format by extension: png/jpg/webp/...);
# snaps a live `just run` if one is up, else boots a throwaway. e.g. just screenshot shot.png
screenshot path: build
	boot/screenshot.sh {{path}}

# drive a live instance for debugging: boot it, run shell commands in it and get
# their output back, tail the serial log, capture packets, type on the keyboard.
# e.g. `just lab boot --fresh`, `just lab sh time ls`, `just lab help`
lab *args:
	boot/lab.py {{args}}

# build a bootable hybrid ISO (BIOS + UEFI) -> boot/.build/<product>.iso; STRIP=debug|all
iso strip="debug": build
	STRIP={{strip}} boot/mkimage.sh iso {{kernel_elf}}

# build a raw bootable disk image for USB / SD card / HDD (BIOS + UEFI); SIZE e.g. 128M, 1G; STRIP=debug|all
img size="64M" strip="debug": build
	STRIP={{strip}} boot/mkimage.sh img {{kernel_elf}} {{size}}

# host-test pure application-side pixel, input, PCM and image helpers
app-libs-test:
	cargo test --manifest-path {{pix_dir}}/Cargo.toml --target x86_64-unknown-linux-gnu
	cargo test --manifest-path {{keys_dir}}/Cargo.toml --target x86_64-unknown-linux-gnu
	cargo test --manifest-path {{pcm_dir}}/Cargo.toml --target x86_64-unknown-linux-gnu
	cargo test --manifest-path {{bmp_dir}}/Cargo.toml --target x86_64-unknown-linux-gnu
