# Shared editor + formatter defaults across the repo.
# Mirrors the Libersoft Prettier style: hard tabs and LF line endings.
# Also consumed by shfmt for shell-script formatting.
root = true

[*]
indent_style = tab
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
